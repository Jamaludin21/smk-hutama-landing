generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================
// ENUMS
// =============================
enum Role {
  ADMIN
  TEACHER
}

enum Gender {
  LAKI_LAKI
  PEREMPUAN
}

enum KelasGuru {
  Lanjutan_1
  Lanjutan_2
  Dasar_1
  Dasar_2
  Wirausaha
}

enum Grade {
  A         // Mandiri
  A_Pi      // Mandiri dengan sedikit bantuan (isyarat/diingatkan)
  A_Pi_Pvis // Masih dibantu isyarat & visual
  P_Pv_Pvis // Bantuan penuh: visual, verbal, fisik
}

enum PresenceStatus {
  ontime
  late
  early
}


// =============================
// USER MODEL (ADMIN / TEACHER)
// =============================
model User {
  id           String   @id @default(cuid())
  name         String?
  username     String   @unique
  email        String?  @unique
  phoneNumber  String?  @unique
  password     String
  avatar       String?
  role         Role     @default(TEACHER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  // Relations
  createdUsers   User[]   @relation("UserCreatedUsers")
  createdBy      User?    @relation("UserCreatedUsers", fields: [createdById], references: [id])
  createdById    String?

  agendas        Agenda[]
  karyaSiswa     KaryaSiswa[]
  galeri         Galeri[]
  presensi       Presensi[]
}

// =============================
// PENDAFTARAN SISWA BARU
// =============================
model PendaftaranSiswaBaru {
  id              String   @id @default(cuid())
  namaSiswa       String
  jenisKelamin    Gender
  alamat          String
  tempatTinggal   String
  tanggalLahir    DateTime
  namaOrangTua    String
  noHpOrangTua    String
  tanggalDaftar   DateTime @default(now())
  isApproved      Boolean  @default(false)
  siswaId         String?  @unique
  siswa           Siswa?   @relation(fields: [siswaId], references: [id], onDelete: Cascade)
}

// =============================
// DATA SISWA
// =============================
model Siswa {
  id              String             @id @default(cuid())
  nis             String             @unique
  nama            String
  jenisKelamin    Gender
  alamat          String
  tempatTinggal   String
  tanggalLahir    DateTime
  kelas           String
  avatar          String?

  // Relations
  karya           KaryaSiswa[]
  penilaianSiswa  PenilaianSiswa[]
  pendaftaran     PendaftaranSiswaBaru?
}

// =============================
// PENILAIAN SISWA
// =============================
model PenilaianSiswa {
  id          String   @id @default(cuid())
  siswaId     String
  siswa       Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tanggal     DateTime @default(now())

  // 1. Perilaku
  regulasiDiri         Grade
  sikapKerja           Grade

  // 2. Komunikasi Fungsional
  komunikasiFungsional Grade

  // 3. Interaksi Sosial
  interaksiSosial      Grade

  // 4. Kemandirian
  binaDiri             Grade
  penggunaanWaktu      Grade

  // 5. Non Akademis
  housekeeping         Grade
  laundry              Grade
  keterampilanTangan   Grade
  olahraga             Grade

  // 6. Akademis
  bacaTulisBahasa      Grade
  matematika           Grade
  pengetahuanUmum      Grade
  outing               Grade

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// =============================
// KARYA SISWA
// =============================
model KaryaSiswa {
  id           String   @id @default(cuid())
  judul        String
  slug         String   @unique
  pemilikId    String
  pemilik      Siswa    @relation(fields: [pemilikId], references: [id], onDelete: Cascade)
  kelas        String
  fileUrl      String
  deskripsi    String?
  price        Float
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// =============================
// AGENDA
// =============================
model Agenda {
  id           String   @id @default(cuid())
  judul        String
  slug         String   @unique
  fileUrl      String
  deskripsi    String?
  createdAt    DateTime @default(now())
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// =============================
// GALERI
// =============================
model Galeri {
  id           String   @id @default(cuid())
  judul        String
  slug         String   @unique
  fileUrl      String
  deskripsi    String?
  createdAt    DateTime @default(now())
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// =============================
// ABSENSI
// =============================
model Presensi {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn       DateTime?
  clockOut      DateTime?
  statusIn      PresenceStatus?  // ENUM: 'ontime' or 'late'
  statusOut     PresenceStatus?  // ENUM: 'ontime' or 'early'
  latitudeIn    Float?
  longitudeIn   Float?
  latitudeOut   Float?
  longitudeOut  Float?
  createdAt     DateTime   @default(now())
}
